# Public deploy default: keep AG2/AI surfaces disabled for Vercel demos.
NEXT_PUBLIC_ENABLE_AI_AGENTS=false
ENABLE_AI_AGENTS=false

# Recommended for production metadata, robots, sitemap, and social preview URLs.
# Example: https://your-demo-url.vercel.app
NEXT_PUBLIC_SITE_URL=

# Required for local conda-backed AI features when ENABLE_AI_AGENTS=true and AG2_SERVICE_URL is unset.
# If AG2_SERVICE_URL is set, the containerized AG2 service can own this key instead.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4o-mini when unset.
OPENAI_MODEL=gpt-4o-mini

# Optional. Point Next.js API routes at a containerized AG2 service.
# Example: http://localhost:8000 locally, or the HTTPS URL from Render/Railway/Fly.
AG2_SERVICE_URL=

# Required when AG2_SERVICE_URL is set. Use the same random 32+ character value in Vercel and the AG2 service host.
AG2_SERVICE_TOKEN=

# Optional. AI route rate limiting for public AI-enabled deployments.
AI_AGENT_RATE_LIMIT_WINDOW_MS=60000
AI_AGENT_RATE_LIMIT_MAX=20

# Optional. The Next.js API routes run AG2 through this conda env when AG2_SERVICE_URL is unset.
AG2_CONDA_ENV=wikidata

# Optional. Set to a Python executable to bypass conda discovery.
AG2_PYTHON=

# Optional. Keep FastAPI /docs and /openapi.json disabled by default in the AG2 container.
AG2_ENABLE_DOCS=false

# Optional. Bounded retry settings for transient AG2/OpenAI/service failures.
AG2_AGENT_MAX_ATTEMPTS=2
AG2_AGENT_RETRY_BASE_MS=800
AG2_AGENT_RETRY_MAX_MS=2500

# Optional. Send sanitized API failure events to a hosted monitor webhook.
# HTTPS is required outside localhost.
API_OBSERVABILITY_WEBHOOK_URL=
API_OBSERVABILITY_WEBHOOK_TOKEN=

# Optional. Token for the built-in /api/observability/events receiver.
# Defaults to API_OBSERVABILITY_WEBHOOK_TOKEN when unset.
API_OBSERVABILITY_RECEIVER_TOKEN=

# Optional. Enable token-protected, project-backed workspace slot persistence.
# Use a durable mounted directory for hosted/self-hosted deployments.
WORKSPACE_STORE_DIR=
WORKSPACE_STORE_TOKEN=
