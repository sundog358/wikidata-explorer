# Required for /api/chat, /api/entity-summary, and AG2-backed AI features.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4o-mini when unset.
OPENAI_MODEL=gpt-4o-mini

# Optional. The Next.js API routes run AG2 through this conda env by default.
AG2_CONDA_ENV=wikidata

# Optional. Set to a Python executable to bypass conda discovery.
AG2_PYTHON=
